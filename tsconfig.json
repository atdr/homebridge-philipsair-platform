{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["index.js", "eslint.config.js", "src/**/*.js", "test/**/*.js"]
}
