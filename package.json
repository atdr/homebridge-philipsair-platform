{
  "name": "@atdr/homebridge-philipsair-platform",
  "displayName": "Philips Air+ Platform",
  "version": "1.1.0",
  "description": "Homebridge plugin for Philips air purifiers and humidifiers. Supports AC3036, AC1715, AC0850 and more.",
  "author": "atdr (https://github.com/atdr/homebridge-philipsair-platform)",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc",
    "check": "find . -name '*.js' -not -path './node_modules/*' -exec node --check {} ';'",
    "test": "node --test",
    "watch": "npm link && nodemon",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "main": "index.js",
  "files": [
    "index.js",
    "src",
    "config.schema.json",
    "example-config.json"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "homebridge": "^1.11.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "bugs": {
    "url": "https://github.com/atdr/homebridge-philipsair-platform/issues"
  },
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/atdr"
    }
  ],
  "homepage": "https://github.com/atdr/homebridge-philipsair-platform",
  "keywords": [
    "philips",
    "homebridge-plugin",
    "air",
    "purifier",
    "homekit",
    "humidifier",
    "temperature",
    "humidity"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atdr/homebridge-philipsair-platform.git"
  }
}
